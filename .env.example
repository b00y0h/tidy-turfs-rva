# Payload CMS — generate a strong random secret for production
PAYLOAD_SECRET=change-me-in-production

# Database (MongoDB Atlas)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# Contact Form ID — populated automatically by: npm run seed:form
# After running the seed, copy the printed ObjectId here
NEXT_PUBLIC_FORM_ID=

# Resend email adapter — get a key at https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here
